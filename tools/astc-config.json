{
  "_comment": "Configuration for tools/convert_astc.py",
  "_doc": {
    "blocksize": "Default block size for assets without override",
    "quality": "Compression quality (exhaustive = best, fastest = fastest)",
    "colorprofile": "cs for sRGB, cl for linear",
    "min_size": "Minimum width/height in pixels. Sprites smaller than this are excluded (default: 500)",
    "overrides": "Map of filename substrings to ASTC block size overrides",
    "exclusions": "List of filename substrings. Matching files are NEVER converted"
  },

  "blocksize": "12x12",
  "quality": "exhaustive",
  "colorprofile": "cs",
  "min_size": 500,

  "overrides": {
    "NOTE_assets":  {"blocksize": "6x6"},
    "Arrows":       {"blocksize": "6x6"},
    "sustainHold":  {"blocksize": "6x6"},
    "noteSplashes": {"blocksize": "6x6"},
    "icon-":        {"blocksize": "4x4"},
    "GF_assets":    {"blocksize": "12x12"},
    "menuBGBlue":   {"blocksize": "12x12"},
    "stageBack":    {"blocksize": "12x12"},
    "stageFront":   {"blocksize": "12x12"}
  },

  "exclusions": [
    "pixel",
    "Pixel",
    "PIXEL",
    "fonts",
    "Font",
    "alphabet",
    "icon.png",
    "icon-hd.png",
    "logo.png",
    "preloader",
    "Preloader",
    "loading"
  ]
}
